generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

enum UserRole {
  WORKER
  SUPERVISOR
  SENIOR_SUPERVISOR
  ADMIN
  AUDITOR
}

enum TemplateInputType {
  NUMBER
  TEXT
  CHECKBOX
  DROPDOWN
}

enum InspectionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  APPROVED
  REJECTED
}

model User {
  id           String       @id @default(uuid())
  employeeId   String       @unique
  passwordHash String
  role         UserRole
  deviceId     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  inspections  Inspection[] @relation("InspectionAssignedTo")
  approvals    Approval[]   @relation("ApprovalSupervisor")
  auditLogs    AuditLog[]   @relation("AuditLogChangedBy")

  @@index([role])
  @@index([deviceId])
}

model Locomotive {
  id          String       @id @default(uuid())
  locoNumber  String       @unique
  shed        String
  type        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  inspections Inspection[]

  @@index([shed])
  @@index([type])
}

model Template {
  id          String         @id @default(uuid())
  name        String
  version     Int
  isActive    Boolean
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  items       TemplateItem[]
  inspections Inspection[]

  @@unique([name, version])
  @@index([name])
  @@index([isActive])
  @@index([createdAt])
}

model TemplateItem {
  id          String            @id @default(uuid())
  templateId  String
  label       String
  inputType   TemplateInputType
  minValue    Float?
  maxValue    Float?
  isMandatory Boolean
  section     String

  template    Template          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  entries     InspectionEntry[]
  media       Media[]

  @@index([templateId])
  @@index([section])
  @@index([inputType])
}

model Inspection {
  id              String            @id @default(uuid())
  locoId          String
  templateId      String
  assignedTo      String
  status          InspectionStatus
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  rejectionReason String?

  locomotive      Locomotive        @relation(fields: [locoId], references: [id], onDelete: Restrict)
  template        Template          @relation(fields: [templateId], references: [id], onDelete: Restrict)
  assignee        User              @relation("InspectionAssignedTo", fields: [assignedTo], references: [id], onDelete: Restrict)
  entries         InspectionEntry[]
  media           Media[]
  approvals       Approval[]

  @@index([locoId])
  @@index([templateId])
  @@index([assignedTo])
  @@index([status])
  @@index([createdAt])
  @@index([assignedTo, status])
  @@index([locoId, createdAt])
}

model InspectionEntry {
  id             String       @id @default(uuid())
  inspectionId   String
  templateItemId String
  value          String
  isFlagged      Boolean
  remarks        String?

  inspection     Inspection   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  templateItem   TemplateItem @relation(fields: [templateItemId], references: [id], onDelete: Restrict)

  @@index([inspectionId])
  @@index([templateItemId])
  @@index([isFlagged])
  @@index([inspectionId, templateItemId])
}

model Media {
  id             String        @id @default(uuid())
  inspectionId   String
  templateItemId String?
  fileUrl        String
  watermarkMeta  Json

  inspection     Inspection    @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  templateItem   TemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)

  @@index([inspectionId])
  @@index([templateItemId])
}

model Approval {
  id           String         @id @default(uuid())
  inspectionId String
  supervisorId String
  status       ApprovalStatus
  comments     String
  level        Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  inspection   Inspection     @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  supervisor   User           @relation("ApprovalSupervisor", fields: [supervisorId], references: [id], onDelete: Restrict)

  @@index([inspectionId])
  @@index([supervisorId])
  @@index([status])
  @@index([inspectionId, status])
}

model AuditLog {
  id        String   @id @default(uuid())
  entity    String
  entityId  String
  oldData   Json
  newData   Json
  changedBy String
  action    String
  timestamp DateTime

  actor     User     @relation("AuditLogChangedBy", fields: [changedBy], references: [id], onDelete: Restrict)

  @@index([entity, entityId])
  @@index([changedBy])
  @@index([timestamp])
}
